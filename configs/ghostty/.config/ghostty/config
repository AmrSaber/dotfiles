# Theme
background-opacity = 0.85

# Behaviour
maximize = true
window-decoration = false
confirm-close-surface = false
mouse-hide-while-typing = true

# Shell integration
shell-integration = zsh
shell-integration-features = ssh-terminfo,ssh-env,sudo,path,title,no-cursor

# Mac OS
macos-option-as-alt = left

# Optionally load custom config that is not git-tracked
config-file=?custom-config
